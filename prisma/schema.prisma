generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  name                String?
  password            String
  role                UserRole
  nationalId          String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  agentConversations  AgentConversation[]
  agentQuestionEvents AgentQuestionEvent[]
  managedContracts    Contract[]           @relation("ContractAdmin")
  coursesCreated      Course[]             @relation("CourseCreator")
  enrollments         Enrollment[]
  companies           Company[]            @relation("CompanyToUser")
  contracts           Contract[]           @relation("ContractToUser")

  @@index([email])
}

model Company {
  id                 String              @id @default(cuid())
  name               String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  agent              CompanyAgent?
  contracts          Contract[]
  courses            Course[]
  enrollments        Enrollment[]
  preRegisteredUsers PreRegisteredUser[]
  users              User[]              @relation("CompanyToUser")
}

model Contract {
  id                 String              @id @default(cuid())
  companyId          String
  adminId            String?
  adminEmail         String?
  startDate          DateTime
  endDate            DateTime?
  status             ContractStatus      @default(PENDING)
  documentUrl        String?
  maxUsers           Int?                @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  admin              User?               @relation("ContractAdmin", fields: [adminId], references: [id])
  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  courses            Course[]            @relation("ContractToCourse")
  preRegisteredUsers PreRegisteredUser[] @relation("ContractToPreRegisteredUser")
  users              User[]              @relation("ContractToUser")

  @@index([companyId])
}

model PreRegisteredUser {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String?
  nationalId   String?
  companyId    String
  isRegistered Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  company      Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contracts    Contract[] @relation("ContractToPreRegisteredUser")

  @@index([companyId])
}

model Course {
  id                 String           @id @default(cuid())
  title              String
  description        String?
  status             CourseStatus     @default(DRAFT)
  companyId          String?
  creatorId          String
  expertId           String?
  approvedAt         DateTime?
  publishedAt        DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  coverImage         String?
  isStrictNavigation Boolean          @default(true)
  company            Company?         @relation(fields: [companyId], references: [id])
  creator            User             @relation("CourseCreator", fields: [creatorId], references: [id])
  expert             Expert?          @relation(fields: [expertId], references: [id])
  enrollments        Enrollment[]
  finalEvaluation    FinalEvaluation?
  modules            Module[]
  contracts          Contract[]       @relation("ContractToCourse")
}

model Expert {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  courses   Course[]
}

model Module {
  id          String           @id @default(cuid())
  courseId    String
  title       String
  description String?
  order       Int
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  lessons     Lesson[]
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress    ModuleProgress[]

  @@index([courseId])
}

model Lesson {
  id         String           @id @default(cuid())
  moduleId   String
  title      String
  content    String
  order      Int
  videoUrl   String?
  audioUrl   String?
  images     Json?            @default("[]")
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  flashcards Flashcard[]
  module     Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress   LessonProgress[]
  quizzes    Quiz[]

  @@index([moduleId])
}

model Quiz {
  id          String        @id @default(cuid())
  lessonId    String
  question    String
  options     Json
  explanation String?
  order       Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  lesson      Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  attempts    QuizAttempt[]

  @@index([lessonId])
}

model Flashcard {
  id        String   @id @default(cuid())
  lessonId  String
  front     String
  back      String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

model FinalEvaluation {
  id           String              @id @default(cuid())
  courseId     String              @unique
  questions    Json
  passingScore Int                 @default(70)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  timeLimit    Int?
  attempts     EvaluationAttempt[]
  course       Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id                 String              @id @default(cuid())
  userId             String
  courseId           String
  companyId          String
  status             EnrollmentStatus    @default(NOT_STARTED)
  startedAt          DateTime?
  completedAt        DateTime?
  totalTimeSpent     Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  course             Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluationAttempts EvaluationAttempt[]
  lessonProgress     LessonProgress[]
  moduleProgress     ModuleProgress[]
  quizAttempts       QuizAttempt[]

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([companyId])
}

model ModuleProgress {
  id           String     @id @default(cuid())
  enrollmentId String
  moduleId     String
  completed    Boolean    @default(false)
  timeSpent    Int        @default(0)
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  module       Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, moduleId])
  @@index([enrollmentId])
}

model LessonProgress {
  id           String     @id @default(cuid())
  enrollmentId String
  lessonId     String
  completed    Boolean    @default(false)
  timeSpent    Int        @default(0)
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson       Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@index([enrollmentId])
}

model QuizAttempt {
  id           String     @id @default(cuid())
  enrollmentId String
  quizId       String
  score        Int
  answers      Json
  completedAt  DateTime   @default(now())
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  quiz         Quiz       @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([enrollmentId])
  @@index([quizId])
}

model EvaluationAttempt {
  id           String          @id @default(cuid())
  enrollmentId String
  evaluationId String
  score        Int
  passed       Boolean
  answers      Json
  completedAt  DateTime        @default(now())
  aiReasoning  String?
  aiScore      Int?
  enrollment   Enrollment      @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  evaluation   FinalEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([enrollmentId])
  @@index([evaluationId])
}

model Lead {
  id           String     @id @default(cuid())
  nombre       String
  celular      String
  correo       String     @unique
  empresa      String
  cargo        String
  numEmpleados String
  status       LeadStatus @default(SIN_CONTACTAR)
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([correo])
  @@index([status])
}

model CompanyAgent {
  id                  String                 @id @default(cuid())
  companyId           String                 @unique
  name                String
  uiColor             String                 @default("#4f46e5")
  isEnabled           Boolean                @default(true)
  generalInstructions String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  ambiguityEvents     AgentAmbiguityEvent[]
  chunks              AgentChunk[]
  conversations       AgentConversation[]
  questionClusters    AgentQuestionCluster[]
  questionEvents      AgentQuestionEvent[]
  questionTopics      AgentQuestionTopic[]
  sourceDocuments     AgentSourceDocument[]
  company             Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model AgentSourceDocument {
  id         String            @id @default(cuid())
  agentId    String
  title      String
  sourceType AgentSourceType
  mimeType   String?
  filePath   String?
  rawText    String
  status     AgentSourceStatus @default(READY)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  chunks     AgentChunk[]
  agent      CompanyAgent      @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([status])
}

model AgentChunk {
  id                String              @id @default(cuid())
  agentId           String
  documentId        String
  chunkIndex        Int
  content           String
  tokenCount        Int?
  lexicalVector     Json?
  embeddingProvider String
  embeddingModel    String
  embeddingVector   Json
  createdAt         DateTime            @default(now())
  agent             CompanyAgent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  document          AgentSourceDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([agentId])
  @@index([documentId])
}

model AgentConversation {
  id              String                @id @default(cuid())
  agentId         String
  userId          String
  title           String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  ambiguityEvents AgentAmbiguityEvent[]
  agent           CompanyAgent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages        AgentMessage[]
  questionEvents  AgentQuestionEvent[]

  @@index([agentId])
  @@index([userId])
  @@index([updatedAt])
}

model AgentMessage {
  id             String            @id @default(cuid())
  conversationId String
  role           AgentMessageRole
  content        String
  mode           String?
  confidence     Float?
  citations      Json?
  createdAt      DateTime          @default(now())
  conversation   AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

model AgentQuestionTopic {
  id              String                 @id @default(cuid())
  agentId         String
  name            String
  normalizedKey   String
  questionCount   Int                    @default(0)
  answeredCount   Int                    @default(0)
  unresolvedCount Int                    @default(0)
  ambiguousCount  Int                    @default(0)
  lastAskedAt     DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  clusters        AgentQuestionCluster[]
  events          AgentQuestionEvent[]
  agent           CompanyAgent           @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, normalizedKey])
  @@index([agentId])
  @@index([questionCount])
}

model AgentQuestionCluster {
  id                    String               @id @default(cuid())
  agentId               String
  topicId               String?
  canonicalQuestion     String
  normalizedQuestionKey String
  centroidEmbedding     Json?
  questionCount         Int                  @default(0)
  answeredCount         Int                  @default(0)
  unresolvedCount       Int                  @default(0)
  ambiguousCount        Int                  @default(0)
  lastAnswer            String?
  lastMode              String?
  lastConfidence        Float?
  lastAskedAt           DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  agent                 CompanyAgent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  topic                 AgentQuestionTopic?  @relation(fields: [topicId], references: [id])
  events                AgentQuestionEvent[]

  @@index([agentId])
  @@index([topicId])
  @@index([normalizedQuestionKey])
}

model AgentQuestionEvent {
  id                       String                  @id @default(cuid())
  agentId                  String
  conversationId           String?
  userId                   String?
  topicId                  String?
  clusterId                String?
  questionText             String
  normalizedQuestion       String
  questionEmbedding        Json?
  answerText               String?
  mode                     String?
  confidence               Float?
  hasAnswer                Boolean                 @default(false)
  resolution               AgentQuestionResolution @default(UNRESOLVED)
  imageMetadata            Json?
  citationsSnapshot        Json?
  selectedSourceDocumentId String?
  createdAt                DateTime                @default(now())
  ambiguityEvent           AgentAmbiguityEvent?
  agent                    CompanyAgent            @relation(fields: [agentId], references: [id], onDelete: Cascade)
  cluster                  AgentQuestionCluster?   @relation(fields: [clusterId], references: [id])
  conversation             AgentConversation?      @relation(fields: [conversationId], references: [id])
  topic                    AgentQuestionTopic?     @relation(fields: [topicId], references: [id])
  user                     User?                   @relation(fields: [userId], references: [id])

  @@index([agentId])
  @@index([topicId])
  @@index([clusterId])
  @@index([resolution])
  @@index([createdAt])
}

model AgentAmbiguityEvent {
  id                       String              @id @default(cuid())
  agentId                  String
  conversationId           String?
  questionEventId          String?             @unique
  questionText             String
  alternatives             Json
  selectedSourceDocumentId String?
  resolvedAt               DateTime?
  createdAt                DateTime            @default(now())
  agent                    CompanyAgent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  conversation             AgentConversation?  @relation(fields: [conversationId], references: [id])
  questionEvent            AgentQuestionEvent? @relation(fields: [questionEventId], references: [id])

  @@index([agentId])
  @@index([resolvedAt])
  @@index([createdAt])
}

model FreeAssessment {
  id           String                  @id @default(cuid())
  title        String
  description  String?
  questions    Json
  passingScore Int                     @default(70)
  timeLimit    Int?
  isActive     Boolean                 @default(true)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  attempts     FreeAssessmentAttempt[]
}

model FreeAssessmentAttempt {
  id              String         @id @default(cuid())
  assessmentId    String
  participantName String
  score           Int
  passed          Boolean
  answers         Json
  completedAt     DateTime       @default(now())
  assessment      FreeAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
}

enum UserRole {
  ADMIN
  CLIENT
  EMPLOYEE
  CONTRACT_ADMIN
}

enum CourseStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  PUBLISHED
}

enum EnrollmentStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  PENDING
}

enum LeadStatus {
  SIN_CONTACTAR
  PRIMER_CONTACTO
  VEINTICUATRO_HORAS_ANTES
  MANANA_MISMO_DIA
  MEDIA_HORA_ANTES
  NO_APARECIO
  CERRADO
  INICIAMOS_TRABAJO
}

enum AgentSourceType {
  TEXT
  FILE
}

enum AgentSourceStatus {
  PROCESSING
  READY
  FAILED
}

enum AgentMessageRole {
  USER
  ASSISTANT
}

enum AgentQuestionResolution {
  ANSWERED
  UNRESOLVED
  AMBIGUOUS
}
